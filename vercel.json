{
  "version": 2,
  "builds": [{
    "src": "api/index.py",
    "use": "@vercel/python",
    "config": {
      "maxLambdaSize": "50mb",
      "includeFiles": ["api/templates/**","api/static/**","api/resume_agent/**"]
    }
  }],
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "functions": { "api/index.py": { "maxDuration": 60 } }
}
